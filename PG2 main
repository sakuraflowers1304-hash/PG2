def add_item(items_dict):
    try:
        name = input("Enter item name: ").strip()
        quantity = int(input("Enter quantity: "))
        price = float(input("Enter price: "))
        if price < 0:
            print("Price cannot be negative!")
            return
        items_dict[name] = Item(name, quantity, price)
        print(f"{name} added successfully!")
    except ValueError:
        print("Invalid input!")

def edit_item(items_dict):
    name = input("Enter item name to edit: ").strip()
    if name in items_dict:
        item = items_dict[name]
        print(f"Current details → Name: {item.name}, Quantity: {item.quantity}, Price: {item.price:.2f}, Total: {item.total_price:.2f}")
        try:
            new_quantity = int(input("Enter new quantity: "))
            new_price = float(input("Enter new price: "))
            if new_price < 0:
                print("Price cannot be negative!")
                return
            # Update item
            items_dict[name] = Item(name, new_quantity, new_price)
            print(f"{name} updated successfully!")
        except ValueError:
            print("Invalid input! Quantity must be integer, price must be number.")
    else:
        print("Error: Item not found!")

def sell_item(items_dict):
    name = input("Enter item name sold: ").strip()
    if name in items_dict:
        try:
            sold_qty = int(input("Enter quantity sold: "))
            if sold_qty <= items_dict[name].quantity:
                items_dict[name].quantity -= sold_qty
                items_dict[name].total_price = items_dict[name].calculate_total()
                print(f"{sold_qty} {name}(s) sold successfully!")
            else:
                print("Not enough stock!")
        except ValueError:
            print("Invalid input!")
    else:
        print("Item not found!")

def display_items(items_dict, title):
    print(f"\n--- {title} ---")
    if items_dict:
        print("{:<5}{:<15}{:<10}{:<10}{:<10}".format(
            "No.", "Name", "Quantity", "Price", "Total"))

        for i, item in enumerate(items_dict.values(), start=1):
            print("{:<5}{:<15}{:<10}{:<10.2f}{:<10.2f}".format(
                i,
                item.name,
                item.quantity,
                item.price,
                item.total_price
            ))
    else:
        print("No items yet.")
    
import csv

def save_to_csv(original_items):
    with open("stationery_items.csv", "w", newline="") as file:
        writer = csv.writer(file)

        writer.writerow(["Name", "Quantity", "Price", "Total"])

        for item in original_items.values():
            writer.writerow([
                item.name,
                item.quantity,
                item.price,
                item.total_price
            ])

    print("Items saved to stationery_items.csv")
